---
interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
}

const {
  title,
  description = "Modernes Website-Konzept fuer Firmenseminare, Qualifizierung und Personalperspektiven.",
  bodyClass = "",
} = Astro.props;

const base = import.meta.env.BASE_URL;
const url = (path = "") => `${base}${path.replace(/^\//, "")}`;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class={bodyClass}>
    <header class="site-header">
      <a class="brand" href={url()} aria-label="[Submarke] Startseite">
        <span class="brand__mark">[Submarke]</span>
        <span class="brand__line">Ein Angebot von Donner + Partner</span>
      </a>
      <nav class="nav" aria-label="Hauptnavigation">
        <a href={url("unternehmen")}>Für Unternehmen</a>
        <a href={url("seminare")}>Seminare</a>
        <a href={url("qualifizierung")}>Qualifizierung</a>
        <a href={url("system")}>System</a>
      </nav>
      <div class="header-actions">
        <a class="button button--ghost" href={url("login")}>Login-Demo</a>
        <a class="button" href={url("kontakt")}>Kontakt</a>
      </div>
    </header>
    <slot />
    <footer class="site-footer">
      <div>
        <strong>[Submarke]</strong>
        <span>Ein Angebot von Donner + Partner</span>
      </div>
      <nav aria-label="Footer">
        <a href={url("unternehmen")}>Für Unternehmen</a>
        <a href={url("seminare")}>Seminare</a>
        <a href={url("login")}>Login-Demo</a>
        <a href="#">Impressum</a>
        <a href="#">Datenschutz</a>
      </nav>
    </footer>
  </body>
</html>
