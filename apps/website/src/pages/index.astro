---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const url = (path = "") => `${base}${path.replace(/^\//, "")}`;

const processSteps = [
  { title: "Firmenschulung", text: "Ein konkretes Thema schafft den Einstieg in die Zusammenarbeit." },
  { title: "Bedarfsanalyse", text: "Personalengpässe, Rollen und Kompetenzlücken werden greifbar." },
  { title: "Qualifizierung", text: "Arbeitsuchende werden gezielt auf reale Firmenbedarfe vorbereitet." },
  { title: "Vermittlung", text: "Profile und Anforderungen werden passgenau zusammengeführt." },
  { title: "Feedback", text: "Erfahrungen aus Seminar und Einstieg fließen in die nächsten Schritte." },
];

const benefits = [
  "Praxisnaher Einstieg für KMU",
  "Region Tauberfranken/Würzburg",
  "Gezielte Personalqualifizierung",
  "Passgenaue Vermittlung vorbereiten",
];

const topics = [
  "Führung & Mitarbeiterbindung",
  "Vertrieb & Kundenkommunikation",
  "Rhetorik & Konfliktmanagement",
  "Prävention & Resilienz",
];

const roadmap = [
  "Firmen, Coaches und Stellen",
  "Seminaranfragen und Angebote",
  "Angebote und Verträge",
  "Feedback und Matching",
];
---

<BaseLayout title="[Submarke] | Firmenseminare und Personalperspektiven" bodyClass="home-page">
  <main>
    <section class="hero hero--showcase">
      <div class="hero__copy">
        <p class="eyebrow">Firmenschulungen für KMU in Tauberfranken/Würzburg</p>
        <h1>Praxisnahe Schulungen, die Personalbedarf mitdenken</h1>
        <p>
          Donner + Partner verbindet Weiterbildung für bestehende Teams mit
          gezielter Qualifizierung von Arbeitsuchenden, die auf konkrete
          Unternehmensbedarfe vorbereitet werden.
        </p>
        <div class="actions">
          <a class="button" href={url("kontakt")}>Kostenfreies Erstgespräch anfragen</a>
          <a class="button button--ghost" href={url("seminare")}>Seminare ansehen</a>
        </div>
      </div>
      <div class="hero-visual" aria-label="Seminar- und Prozessvorschau">
        <img
          src={url("images/start.png")}
          alt="Website-Vorschau mit Seminar, Recruiting und regionalen Branchen"
        />
        <div class="floating-card floating-card--need">
          <span>Bedarfsanalyse</span>
          <strong>offene Rollen klären</strong>
        </div>
        <div class="floating-card floating-card--score">
          <span>Regionale Stärke</span>
          <strong>KMU im Fokus</strong>
        </div>
      </div>
    </section>

    <section class="process-band" aria-label="Prozess">
      {processSteps.map((step, index) => (
        <article>
          <span>{String(index + 1).padStart(2, "0")}</span>
          <h2>{step.title}</h2>
          <p>{step.text}</p>
        </article>
      ))}
    </section>

    <section class="split-panel">
      <div>
        <p class="eyebrow">Warum der Einstieg funktioniert</p>
        <h2>Firmenschulungen schaffen Vertrauen, bevor Vermittlung konkret wird</h2>
        <p>
          Unternehmen erhalten sofort nutzbare Weiterbildung. Gleichzeitig
          entsteht ein Gespräch über Personalengpässe, Einarbeitung,
          Mitarbeiterbindung und passende Qualifizierung.
        </p>
      </div>
      <div class="benefit-grid">
        {benefits.map((benefit) => <span>{benefit}</span>)}
      </div>
    </section>

    <section class="topic-section">
      <div class="section-heading">
        <p class="eyebrow">Seminarbeispiele</p>
        <h2>Konkrete Themen für den ersten Kontakt</h2>
      </div>
      <div class="topic-rail">
        {topics.map((topic) => <a href={url("seminare")}>{topic}</a>)}
      </div>
    </section>

    <section class="app-preview">
      <div>
        <p class="eyebrow">Systemausblick</p>
        <h2>Ein eigener Systemausblick, ohne produktive Daten</h2>
        <p>
          Die spätere App kann Seminaranfragen, Firmenprofile, Angebote,
          Coach-Profile, Stellen, Verträge, Feedback und Matching
          unterstützen. Dieser Bereich bleibt zunächst eine realistische
          Vorschau ohne echten Login und ohne Datenbank.
        </p>
        <a class="button button--ghost" href={url("login")}>Login-Demo öffnen</a>
      </div>
      <div class="dashboard-card" aria-label="App-Vorschau">
        <div class="dashboard-card__top">
          <span>Demo-Dashboard</span>
          <strong>Bedarfsanalyse</strong>
        </div>
        {roadmap.map((item, index) => (
          <div class="pipeline-row">
            <span>{String(index + 1).padStart(2, "0")}</span>
            <strong>{item}</strong>
            <em>{index === 0 ? "aktiv" : "geplant"}</em>
          </div>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
