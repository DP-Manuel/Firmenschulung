---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const url = (path = "") => `${base}${path.replace(/^\//, "")}`;

const steps = [
  "Schulung oder Erstgespräch als Anlass nutzen",
  "Bedarfsanalyse mit dem Unternehmen durchführen",
  "Arbeitsuchende über bestehende Kurse gezielt vorbereiten",
  "Profile und Anforderungen regelbasiert vergleichen",
  "Vermittlung begleiten und Firmenfeedback einholen",
];
---

<BaseLayout title="Qualifizierung | [Submarke]">
  <main class="subpage">
    <section class="page-hero">
      <p class="eyebrow">Qualifizierung & Vermittlung</p>
      <h1>Vom Unternehmensbedarf zur passgenauen Qualifizierung</h1>
      <p>
        Das Modell verbindet Schulung, Bedarfsanalyse und Vermittlung:
        Arbeitsuchende können in bestehenden Kursen gezielt auf konkrete
        Anforderungen vorbereitet werden, ohne zunächst bereits Lehrpläne
        oder produktive Datenflüsse festzulegen.
      </p>
    </section>

    <figure class="subpage-image">
      <img
        src={url("images/qualifizierung.png")}
        alt="Visualisierung gezielter Qualifizierung und Lernbegleitung"
      />
    </figure>

    <section class="timeline-list">
      {steps.map((step, index) => (
        <article>
          <span>{String(index + 1).padStart(2, "0")}</span>
          <p>{step}</p>
        </article>
      ))}
    </section>
  </main>
</BaseLayout>
