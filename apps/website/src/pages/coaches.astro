---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const url = (path = "") => `${base}${path.replace(/^\//, "")}`;

const coaches = [
  {
    name: "Christian Galvano",
    initials: "CG",
    role: "Dozent, Fachtrainer und Coach",
    focus: [
      "Neuroleadership",
      "Konfliktmanagement",
      "Stress- und Burnoutprävention",
    ],
    text: "Christian Galvano verbindet neurowissenschaftliche Grundlagen mit praxisnahen Methoden für Führung, Kommunikation und gesundes Arbeiten.",
    profilePath: "coaches/christian-galvano",
  },
];
---

<BaseLayout title="Coaches | [Submarke]">
  <main class="subpage">
    <section class="page-hero page-hero--accent">
      <p class="eyebrow">Coaches & Dozenten</p>
      <h1>Fachwissen mit Persönlichkeit und Praxiserfahrung</h1>
      <p>
        Lernen Sie die Menschen kennen, die unsere Firmenschulungen fachlich
        fundiert, verständlich und mit Blick auf den Arbeitsalltag gestalten.
      </p>
      <a class="button" href={url("kontakt")}>Coach-Einsatz anfragen</a>
    </section>

    <figure class="subpage-image">
      <img
        src={url("images/recruiting.png")}
        alt="Visualisierung von Recruiting und persönlicher Beratung"
      />
    </figure>

    <section class="coach-grid" aria-label="Coaches und Dozenten">
      {coaches.map((coach) => (
        <article class="coach-card coach-card--featured">
          <div class="coach-card__media" aria-hidden="true">
            <span>{coach.initials}</span>
          </div>
          <div>
            <p class="eyebrow">Coach & Dozent</p>
            <h2>{coach.name}</h2>
            <strong>{coach.role}</strong>
            <ul class="tag-list" aria-label="Themenschwerpunkte">
              {coach.focus.map((topic) => <li>{topic}</li>)}
            </ul>
            <p>{coach.text}</p>
            <a class="button button--ghost" href={url(coach.profilePath)}>
              Profil ansehen
            </a>
          </div>
        </article>
      ))}
    </section>

    <section class="showcase-strip">
      <div>
        <p class="eyebrow">Redaktionsausblick</p>
        <h2>Weitere Profile strukturiert ergänzen</h2>
      </div>
      <p>
        Coachprofile sollen langfristig strukturiert gepflegt werden: Name,
        Rolle, Themenschwerpunkte, Qualifikation, Einsatzregion, Bild und
        Freigabestatus. Ob das über CMS, Webapp oder API passiert, bleibt eine
        Entscheidung vor dem Live-Betrieb.
      </p>
    </section>
  </main>
</BaseLayout>
