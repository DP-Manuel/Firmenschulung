---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const url = (path = "") => `${base}${path.replace(/^\//, "")}`;

const coaches = [
  {
    name: "Christian Galvano",
    initials: "CG",
    role: "Dozent, Fachtrainer und Coach",
    focus: [
      "Neuroleadership",
      "Konfliktmanagement",
      "Stress- und Burnoutprävention",
    ],
    text: "Christian Galvano verbindet neurowissenschaftliche Grundlagen mit praxisnahen Methoden für Führung, Kommunikation und gesundes Arbeiten.",
    profilePath: "coaches/christian-galvano",
  },
];
---

<BaseLayout title="Coaches | [Submarke]">
  <main class="subpage">
    <section class="page-hero page-hero--accent coach-list-hero">
      <div>
        <p class="eyebrow">Coaches & Dozenten</p>
        <h1>Fachwissen mit Persönlichkeit und Praxiserfahrung</h1>
        <p>
          Lernen Sie die Menschen kennen, die unsere Firmenschulungen fachlich
          fundiert, verständlich und mit Blick auf den Arbeitsalltag gestalten.
        </p>
        <a class="button" href={url("kontakt")}>Coach-Einsatz anfragen</a>
      </div>
      <aside class="coach-list-hero__note" aria-label="Unser Anspruch">
        <span>Unser Anspruch</span>
        <strong>Fachlich fundiert.<br />Praxisnah.<br />Persönlich.</strong>
      </aside>
    </section>

    <section class="coach-grid" aria-label="Coaches und Dozenten">
      {coaches.map((coach) => (
        <article class="coach-card coach-card--featured">
          <div class="coach-card__media">
            <img
              src={url("images/coaches/christian-galvano.webp")}
              alt="Porträt von Christian Galvano"
              width="830"
              height="830"
              loading="lazy"
            />
          </div>
          <div>
            <p class="eyebrow">Coach & Dozent</p>
            <h2>{coach.name}</h2>
            <strong>{coach.role}</strong>
            <ul class="tag-list" aria-label="Themenschwerpunkte">
              {coach.focus.map((topic) => <li>{topic}</li>)}
            </ul>
            <p>{coach.text}</p>
            <a class="button button--ghost" href={url(coach.profilePath)}>
              Profil ansehen
            </a>
          </div>
        </article>
      ))}
    </section>

    <section class="showcase-strip coach-list-cta">
      <div>
        <p class="eyebrow">Individuell zusammenstellen</p>
        <h2>Passenden Coach finden</h2>
      </div>
      <div>
        <p>
          Wir stimmen Fachgebiet, Zielgruppe und Format auf die konkrete
          Situation in Ihrem Unternehmen ab.
        </p>
        <a class="button" href={url("kontakt")}>
          Kostenfreies Erstgespräch anfragen
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
