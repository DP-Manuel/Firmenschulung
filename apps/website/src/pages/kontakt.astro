---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";
---

<BaseLayout title="Kontakt | [Submarke]">
  <main class="subpage">
    <section class="contact-page">
      <div>
        <p class="eyebrow">Kontakt</p>
        <h1>Kostenfreies Erstgespräch zur Bedarfsanalyse</h1>
        <p>
          Ob Firmenschulung, Personalengpass oder Qualifizierungsbedarf: Der
          erste Schritt ist ein kurzes Gespräch. Für die Präsentation bleibt
          dieses Formular eine visuelle Vorschau ohne echte Verarbeitung.
        </p>
      </div>
      <form class="contact-form" aria-label="Kontaktformular Demo">
        <label>
          Name
          <input name="name" type="text" placeholder="Vor- und Nachname" />
        </label>
        <label>
          Unternehmen
          <input name="company" type="text" placeholder="Unternehmen" />
        </label>
        <label>
          Telefon
          <input name="phone" type="tel" placeholder="Telefonnummer" />
        </label>
        <label>
          Anliegen
          <select name="interest">
            <option>Firmenschulung</option>
            <option>Bedarfsanalyse</option>
            <option>Personalqualifizierung</option>
            <option>Vermittlung</option>
          </select>
        </label>
        <label class="contact-form__wide">
          Nachricht
          <textarea name="message" rows="5" placeholder="Worum geht es?"></textarea>
        </label>
        <button class="button contact-form__wide" type="button">Demo-Erstgespräch anfragen</button>
      </form>
    </section>
  </main>
</BaseLayout>
