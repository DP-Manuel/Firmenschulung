---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const url = (path = "") => `${base}${path.replace(/^\//, "")}`;

const cards = [
  {
    title: "Schulung als Einstieg",
    text: "Ein konkretes Thema schafft Gesprächsanlass und zeigt schnell, wo im Unternehmen Bedarf besteht.",
  },
  {
    title: "Personalbedarf klären",
    text: "Offene Stellen, Einarbeitungshürden, Quereinsteigerbedarf und Mitarbeiterbindung werden strukturiert besprochen.",
  },
  {
    title: "Bewerber vorbereiten",
    text: "Arbeitsuchende aus bestehenden Maßnahmen können gezielt auf reale Anforderungen vorbereitet werden.",
  },
  {
    title: "Passgenau vermitteln",
    text: "Der spätere Prozess führt Qualifikation, Bedarf und regionale Nähe nachvollziehbar zusammen.",
  },
];
---

<BaseLayout title="Für Unternehmen | [Submarke]">
  <main class="subpage">
    <section class="page-hero">
      <p class="eyebrow">Für Unternehmen</p>
      <h1>Ein regionaler Partner für Schulung und Fachkräftebedarf</h1>
      <p>
        Für KMU in Tauberfranken/Würzburg verbinden wir praxisnahe
        Firmenschulungen mit gezielter Personalqualifizierung und einem klaren
        Blick auf offene Stellen.
      </p>
      <a class="button" href={url("kontakt")}>Kostenfreies Erstgespräch anfragen</a>
    </section>

    <figure class="subpage-image">
      <img
        src={url("images/partnerschaft.png")}
        alt="Symbolische Darstellung einer partnerschaftlichen Zusammenarbeit"
      />
    </figure>

    <section class="feature-grid">
      {cards.map((card) => (
        <article class="feature-card">
          <h2>{card.title}</h2>
          <p>{card.text}</p>
        </article>
      ))}
    </section>

    <section class="showcase-strip">
      <div>
        <p class="eyebrow">Wirkung für Unternehmen</p>
        <h2>Ein geschlossener Kreislauf statt einzelner Insellösungen</h2>
      </div>
      <p>
        Unternehmen schulen bestehende Teams und erhalten zugleich Zugang zu
        Bewerbern, die über vorhandene Maßnahmen passend nachqualifiziert
        werden können. Die Unternehmensseite kann später schlanker gefasst
        oder mit echten Referenzen ergänzt werden.
      </p>
    </section>
  </main>
</BaseLayout>
