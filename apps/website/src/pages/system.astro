---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const url = (path = "") => `${base}${path.replace(/^\//, "")}`;

const modules = [
  "Firmenprofile",
  "Coachprofile",
  "Stellenanzeigen",
  "Seminaranfragen",
  "Angebote",
  "Vermittlungsvereinbarungen",
  "Feedback nach Seminaren",
  "Regelbasiertes Matching",
  "Redaktionsworkflow",
];
---

<BaseLayout title="Systemausblick | [Submarke]">
  <main class="subpage">
    <section class="page-hero page-hero--system">
      <p class="eyebrow">Systemausblick</p>
      <h1>Ein späteres System für Firmen, Coaches und Stellen</h1>
      <p>
        Der Ausblick zeigt die Richtung. Das spätere System soll unabhängig
        arbeiten, eigene Daten nutzen und interne Abläufe rund um Seminare,
        Firmen, Coachprofile, Stellen, Verträge, Feedback und Vermittlung
        schrittweise vereinfachen.
      </p>
      <a class="button" href={url("login")}>Login-Demo ansehen</a>
    </section>

    <figure class="subpage-image">
      <img
        src={url("images/digitale-lernplattform.png")}
        alt="Visualisierung eines digitalen Lern- und Verwaltungssystems"
      />
    </figure>

    <section class="module-board">
      {modules.map((module) => <article>{module}</article>)}
    </section>

    <section class="showcase-strip">
      <div>
        <p class="eyebrow">Bewusst noch nicht produktiv</p>
        <h2>Keine echte Datenbank, keine echten Accounts</h2>
      </div>
      <p>
        Der nächste Schritt ist das Bild: Wie könnte sich die Website in ein
        professionelles System weiterentwickeln? Firmen-, Coach-, Stellen- und
        interne Rollenfunktionen bleiben noch offen und werden nicht als final
        gezeigt.
      </p>
    </section>
  </main>
</BaseLayout>
