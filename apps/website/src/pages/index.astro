---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const url = (path = "") => `${base}${path.replace(/^\//, "")}`;

const processSteps = [
  { title: "Seminar", text: "Unternehmen steigen über konkrete Weiterbildungsthemen ein." },
  { title: "Bedarf", text: "Personal- und Kompetenzlücken werden im Gespräch sichtbar." },
  { title: "Qualifizierung", text: "Bestehende Maßnahmen werden auf reale Anforderungen ausgerichtet." },
  { title: "Matching", text: "Profile, Kompetenzen und Stellen werden nachvollziehbar abgeglichen." },
  { title: "Einstieg", text: "Der Start wird begleitet und Erfahrungen fließen zurück." },
];

const benefits = [
  "Seminare als niedrigschwelliger Einstieg",
  "Bedarfe früher erkennen",
  "Qualifizierung gezielter planen",
  "Vermittlung anschlussfähig vorbereiten",
];

const topics = ["KI im Büroalltag", "Kommunikation", "Führung", "Vertrieb", "Mitarbeitendenbindung"];

const roadmap = [
  "Firmenprofile und Aufträge",
  "Seminar- und Coach-Verwaltung",
  "Angebote und Verträge",
  "Score-basiertes Matching",
];
---

<BaseLayout title="[Submarke] | Firmenseminare und Personalperspektiven" bodyClass="home-page">
  <main>
    <section class="hero hero--showcase">
      <div class="hero__copy">
        <p class="eyebrow">Modernes Angebot für Unternehmen</p>
        <h1>Aus Seminaren wird Personalperspektive</h1>
        <p>
          Wir verbinden Firmenseminare, Unternehmensbedarf und gezielte
          Qualifizierung zu einem nachvollziehbaren Weg von der ersten
          Anfrage bis zur passenden Besetzung.
        </p>
        <div class="actions">
          <a class="button" href={url("kontakt")}>Beratungsgespräch anfragen</a>
          <a class="button button--ghost" href={url("seminare")}>Seminare ansehen</a>
        </div>
      </div>
      <div class="hero-visual" aria-label="Seminar- und Prozessvorschau">
        <img
          src="https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=900&q=80"
          alt="Trainerin präsentiert in einem modernen Seminarraum"
        />
        <div class="floating-card floating-card--need">
          <span>Bedarf erkannt</span>
          <strong>3 offene Rollen</strong>
        </div>
        <div class="floating-card floating-card--score">
          <span>Matching-Ausblick</span>
          <strong>86 Punkte</strong>
        </div>
      </div>
    </section>

    <section class="process-band" aria-label="Prozess">
      {processSteps.map((step, index) => (
        <article>
          <span>{String(index + 1).padStart(2, "0")}</span>
          <h2>{step.title}</h2>
          <p>{step.text}</p>
        </article>
      ))}
    </section>

    <section class="split-panel">
      <div>
        <p class="eyebrow">Warum der Einstieg funktioniert</p>
        <h2>Seminare schaffen Vertrauen, bevor Vermittlung konkret wird</h2>
        <p>
          Unternehmen erhalten sofort nutzbare Weiterbildung. Gleichzeitig
          entsteht ein Gespräch über echte Personalbedarfe, Qualifizierung und
          passende nächste Schritte.
        </p>
      </div>
      <div class="benefit-grid">
        {benefits.map((benefit) => <span>{benefit}</span>)}
      </div>
    </section>

    <section class="topic-section">
      <div class="section-heading">
        <p class="eyebrow">Seminarbeispiele</p>
        <h2>Konkrete Themen für den ersten Kontakt</h2>
      </div>
      <div class="topic-rail">
        {topics.map((topic) => <a href={url("seminare")}>{topic}</a>)}
      </div>
    </section>

    <section class="app-preview">
      <div>
        <p class="eyebrow">Nach dem 01.07. geplant</p>
        <h2>Ein eigenes System, nicht nur eine Website</h2>
        <p>
          Die spätere App soll intern verwalten, was heute mühsam verteilt ist:
          Firmen, Seminare, Coaches, Teilnehmende, Angebote, Verträge,
          Matching und Dokumentpakete. Für die Präsentation zeigen wir nur eine
          realistische Vorschau.
        </p>
        <a class="button button--ghost" href={url("login")}>Login-Demo öffnen</a>
      </div>
      <div class="dashboard-card" aria-label="App-Vorschau">
        <div class="dashboard-card__top">
          <span>Demo-Dashboard</span>
          <strong>Seminarpipeline</strong>
        </div>
        {roadmap.map((item, index) => (
          <div class="pipeline-row">
            <span>{String(index + 1).padStart(2, "0")}</span>
            <strong>{item}</strong>
            <em>{index === 0 ? "aktiv" : "geplant"}</em>
          </div>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
