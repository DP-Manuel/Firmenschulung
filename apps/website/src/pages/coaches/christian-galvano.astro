---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/global.css";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const url = (path = "") => `${base}${path.replace(/^\//, "")}`;

const seminars = [
  {
    title: "Neuroleadership",
    text: "Neurowissenschaftlich fundierte Impulse für Führung, Mitarbeitermotivation, Veränderung und mentale Stärke.",
  },
  {
    title: "Konfliktmanagement",
    text: "Praxisnahe Kommunikations- und Verhandlungsstrategien für konstruktive Konfliktklärung und Zusammenarbeit.",
  },
  {
    title: "Stress- und Burnoutprävention",
    text: "Stressmechanismen verstehen, Ressourcen stärken und wirksame Methoden für einen gesunden Arbeitsalltag anwenden.",
  },
];
---

<BaseLayout
  title="Christian Galvano | Coaches | [Submarke]"
  description="Christian Galvano begleitet Unternehmen als Dozent, Fachtrainer und Coach mit Schwerpunkten in Neuroleadership, Konfliktmanagement sowie Stress- und Burnoutprävention."
>
  <main class="subpage">
    <section class="coach-profile-hero">
      <div>
        <p class="eyebrow">Coach & Dozent</p>
        <h1>Christian Galvano</h1>
        <p class="coach-profile-lead">
          Dozent und Fachtrainer für Neurodidaktik und Neuroleadership,
          Personal- und Business Coach (IHK) sowie Trainer (IHK) in der
          Erwachsenenbildung.
        </p>
        <p>
          Seine Seminare verbinden Erkenntnisse aus Neurowissenschaft und
          Psychologie mit konkreten Werkzeugen für Führung, Kommunikation,
          Veränderung und gesundes Arbeiten.
        </p>
        <div class="coach-profile-actions">
          <a class="button" href={url("kontakt")}>Seminar anfragen</a>
          <a
            class="button button--ghost"
            href="https://changes-galvano.de/"
            target="_blank"
            rel="noopener noreferrer"
          >
            Eigene Website besuchen
          </a>
        </div>
      </div>
      <figure class="coach-profile-portrait">
        <img
          src={url("images/coaches/christian-galvano.webp")}
          alt="Porträt von Christian Galvano"
          width="830"
          height="830"
        />
        <figcaption>
          <strong>Christian Galvano</strong>
          <span>Neurowissenschaften · Führung · Prävention</span>
        </figcaption>
      </figure>
    </section>

    <section class="coach-profile-section">
      <div class="section-heading coach-section-heading">
        <div>
          <p class="eyebrow">Themenschwerpunkte</p>
          <h2>Wissen, das im Arbeitsalltag Wirkung entfaltet</h2>
        </div>
        <p>
          Die Inhalte richten sich an Unternehmen, Führungskräfte und Teams,
          die Veränderung verstehen und verantwortungsvoll gestalten möchten.
        </p>
      </div>

      <div class="coach-topic-grid">
        {seminars.map((seminar) => (
          <article>
            <h3>{seminar.title}</h3>
            <p>{seminar.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="coach-credentials">
      <div>
        <p class="eyebrow">Profil</p>
        <h2>Fachliche Grundlage</h2>
        <p>
          Christian Galvano arbeitet an der Schnittstelle von
          Neurowissenschaften, Erwachsenenbildung und beruflicher
          Entwicklung.
        </p>
      </div>
      <ul>
        <li>Master in Neurowissenschaften (M.Sc. Tech)</li>
        <li>Studium der biologischen Psychologie</li>
        <li>Personal- und Business Coach (IHK)</li>
        <li>Trainer (IHK) in der Erwachsenenbildung</li>
        <li>Dozent und Fachtrainer für Neurodidaktik und Neuroleadership</li>
        <li>Buchautor</li>
      </ul>
    </section>

    <section class="showcase-strip coach-profile-cta">
      <div>
        <p class="eyebrow">Passendes Format besprechen</p>
        <h2>Seminar für Ihr Unternehmen anfragen</h2>
      </div>
      <div>
        <p>
          Gemeinsam klären wir Zielgruppe, Ausgangslage und den passenden
          Schwerpunkt für Ihr Team.
        </p>
        <a class="button" href={url("kontakt")}>
          Kostenfreies Erstgespräch anfragen
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
